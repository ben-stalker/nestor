{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "Node16",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "outDir": "dist-e2e",
    "rootDir": ".",
    "noEmit": true,
    "types": ["node"]
  },
  "include": ["playwright.config.ts", "e2e/**/*.ts", "scripts/**/*.ts"]
}
