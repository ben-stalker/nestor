{
  "name": "@nestor/server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "lint": "eslint . --ext .ts --no-error-on-unmatched-pattern",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "build": "tsc -b",
    "db:reset": "node -e \"if(process.env.NODE_ENV==='production') process.exit(1); require('fs').rmSync(process.env.NESTOR_DB_PATH || require('path').join(require('os').homedir(),'.nestor','nestor.db'),{force:true})\""
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "express": "^5.2.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/supertest": "^7.2.0",
    "jest": "^30.4.2",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": {
            "module": "CommonJS",
            "moduleResolution": "node",
            "types": [
              "jest",
              "node"
            ]
          }
        }
      ]
    }
  }
}
