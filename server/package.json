{
  "name": "@nestor/server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "lint": "eslint . --ext .ts --no-error-on-unmatched-pattern",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "build": "tsc -b",
    "db:reset": "node -e \"if(process.env.NODE_ENV==='production') process.exit(1); require('fs').rmSync(process.env.NESTOR_DB_PATH || require('path').join(require('os').homedir(),'.nestor','nestor.db'),{force:true})\""
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.9.0",
    "cheerio": "^1.2.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "ical.js": "^2.2.1",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "pdf-lib": "^1.17.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "tsdav": "^2.2.1",
    "uuid": "^14.0.0",
    "ws": "^8.20.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node-cron": "^3.0.11",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "jest": "^30.4.2",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": {
            "module": "CommonJS",
            "moduleResolution": "node",
            "types": [
              "jest",
              "node"
            ]
          }
        }
      ]
    }
  }
}
